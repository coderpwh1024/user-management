# 应用配置
APP_NAME=user-management
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
