# 应用配置
APP_NAME=user-management
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=user_management

# 数据库连接池
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=100
DB_POOL_RECYCLE=3600

# Redis 配置
# REDIS_DSN 优先级高于下面的分项配置，示例：redis://:password@127.0.0.1:6379/0
REDIS_DSN=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=1000
REDIS_SOCKET_TIMEOUT=2.0
REDIS_SOCKET_CONNECT_TIMEOUT=2.0
REDIS_HEALTH_CHECK_INTERVAL=30

# 日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
